[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/BattleScene.cs" id="1_battle"]

[node name="BattleScene" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
